# Sunucu Portu
PORT=2222

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=passobot
MONGODB_CONNECT_TIMEOUT_MS=10000

# Takim uyelik sifrelerini uygulama seviyesinde sifrelemek icin
CREDENTIAL_SECRET_KEY=change_me_for_production

# Passo Login URL'i
PASSO_LOGIN=https://www.passo.com.tr/tr/giris

# Cloudflare Turnstile Site Key (Passo sayfasÄ±ndan alÄ±nÄ±r)
PASSO_SITE_KEY=your_turnstile_site_key_here

# AntiCaptcha API Key (https://anti-captcha.com adresinden alÄ±nÄ±r)
ANTICAPTCHA_KEY=your_anticaptcha_api_key_here

# Chrome Executable Path (Opsiyonel)
CHROME_PATH=

# Tarayici pencere boyutu (Opsiyonel - coklu hesapta RAM tasarrufu icin kucultun)
# Ornek: 1280,720 veya 1920,1080
BROWSER_WINDOW_SIZE=1280,720

# User Data Dizinleri
USER_DATA_DIR_A=C:/passobot/user-data-A
USER_DATA_DIR_B=C:/passobot/user-data-B

# SipariÅŸ Log URL'i (Opsiyonel)
ORDER_LOG_URL=

# TarayÄ±cÄ±larÄ± aÃ§Ä±k tut (Opsiyonel - debug iÃ§in)
KEEP_BROWSERS_OPEN=false

# Log Seviyesi (Opsiyonel)
LOG_LEVEL=info

# Rate Limiting AyarlarÄ± (Opsiyonel)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WHITELIST=

# Proxy havuzu: giris basarisizliginda kac farkli proxy denensin (1-8, her denemede onceki Chromium kapanir)
PROXY_POOL_LOGIN_MAX_ATTEMPTS=4

# Turnstile / AntiCaptcha Ayarlari (Opsiyonel)
# Ayni anda kac turnstile cozumu yapilabilsin (coklu hesapta artirin, AntiCaptcha limitine dikkat)
TURNSTILE_SOLVE_CONCURRENCY=4
# Bir sayfada maksimum deneme sayisi
TURNSTILE_MAX_ATTEMPTS=2
# AntiCaptcha solve timeout (ms)
TURNSTILE_SOLVE_TIMEOUT_MS=120000

# Timeout DeÄŸerleri (Opsiyonel - milisaniye)
TURNSTILE_DETECTION_TIMEOUT=7000
CLICK_BUY_RETRIES=12
CLICK_BUY_DELAY=400
SEAT_SELECTION_MAX_MS=50000
SEAT_PICK_EXACT_MAX_MS=90000
SEAT_WAIT_UNTIL_FOUND=0
SEAT_WAIT_MAX_MINUTES=90
NETWORK_CAPTURE_TIMEOUT=20000
SWAL_CONFIRM_TIMEOUT=10000
REMOVE_FROM_CART_TIMEOUT=15000
CATEGORY_SELECTION_RETRIES=12
BLOCKS_WAIT_TIMEOUT=6000
ORDER_LOG_TIMEOUT=15000

# Delay DeÄŸerleri (Opsiyonel - milisaniye)
TURNSTILE_CHECK_DELAY=600
AFTER_LOGIN_DELAY=1200
AFTER_CONTINUE_DELAY=800
SEAT_SELECTION_DELAY=200
CATEGORY_SELECTION_DELAY=500
CLEANUP_DELAY=5000

# Coklu hesap (CF ve Turnstile yukunu azaltmak icin dusuk concurrency + yuksek stagger onerilir)
MULTI_A_CONCURRENCY=3
MULTI_B_CONCURRENCY=3
MULTI_STAGGER_MS=1200

# Sepette Tutma SÃ¼resi AyarlarÄ± (Opsiyonel - saniye)
# Passo'nun sepette tutma sÃ¼resi (varsayÄ±lan: 10 dakika = 600 saniye)
BASKET_HOLDING_TIME_SECONDS=600
# Sepet timeout'undan Ã¶nce ne kadar sÃ¼re kala uyarÄ± verilecek (varsayÄ±lan: 60 saniye)
BASKET_WARNING_BEFORE_TIMEOUT=60
# Sepet timeout'undan Ã¶nce ne kadar sÃ¼re kala koltuÄŸu sepetten kaldÄ±rÄ±lacak (varsayÄ±lan: 30 saniye)
BASKET_REMOVE_BEFORE_TIMEOUT=30



EXPERIMENTAL_A_READD_ON_THRESHOLD=1
EXPERIMENTAL_A_READD_THRESHOLD_SECONDS=480
EXPERIMENTAL_A_READD_COOLDOWN_SECONDS=60
