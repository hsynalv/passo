CATEGORY_SELECTION_DELAY=500
CATEGORY_ROAM_EVERY_CYCLES=4
SVG_CATEGORY_ROAM_MS=10000
BLOCKS_WAIT_TIMEOUT=6000

# ═══════════════════════════════════════════════════════════
# Sepet / Transfer Zamanlama
# ═══════════════════════════════════════════════════════════
